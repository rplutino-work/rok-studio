generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          Int      @id @default(autoincrement())
  projectType String
  platform    String
  budget      String
  timeline    String
  contactInfo String
  status      String   @default("new")
  createdAt   DateTime @default(now())
}
